<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorSecondaryVariant">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondary">@android:color/black</item>
        <item name="android:windowBackground">@drawable/default_background</item>
        <!-- Customize your theme here. -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MyApp.SmallComponent</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MyApp.MediumComponent</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MyApp.LargeComponent</item>
    </style>

    <style name="SplashTheme" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">#307B54</item>
        <item name="android:statusBarColor">#307B54</item>
        <item name="android:navigationBarColor">#307B54</item>
        <item name="android:windowSplashScreenBackground">#307B54</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_splash_system</item>
    </style>

    <style name="MainTheme" parent="AppTheme">
        <item name="android:windowBackground">#307B54</item>
    </style>
</resources>
