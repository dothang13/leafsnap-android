<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F8FA"
    tools:context=".ui.calendar.CalendarActivity">

    <!-- Header Toolbar with Green Gradient Background -->
    <FrameLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@drawable/bg_green_gradient_header"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Back Button -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="12dp"
            android:padding="8dp"
            android:src="@drawable/ic_back_white"
            tools:ignore="ContentDescription" />

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Care Calendar"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:fontFamily="@font/montserrat_bold" />
    </FrameLayout>

    <!-- Calendar Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="3dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Month Switcher Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical">

                <!-- Previous Month Button -->
                <ImageView
                    android:id="@+id/btnPrevMonth"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentStart="true"
                    android:background="@drawable/bg_circle_outline"
                    android:padding="6dp"
                    android:src="@drawable/ic_arrow_left"
                    tools:ignore="ContentDescription" />

                <!-- Current Month / Year Text -->
                <TextView
                    android:id="@+id/tvMonthYear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="July 2026"
                    android:textColor="#111111"
                    android:textSize="18sp"
                    android:fontFamily="@font/montserrat_bold" />

                <!-- Next Month Button -->
                <ImageView
                    android:id="@+id/btnNextMonth"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_circle_outline"
                    android:padding="6dp"
                    android:src="@drawable/ic_arrow_right"
                    tools:ignore="ContentDescription" />
            </RelativeLayout>

            <!-- Sunday - Saturday Header Labels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                android:weightSum="7">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="SU"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:fontFamily="@font/montserrat_medium" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="MO"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:fontFamily="@font/montserrat_medium" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TU"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:fontFamily="@font/montserrat_medium" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="WE"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:fontFamily="@font/montserrat_medium" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="TH"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:fontFamily="@font/montserrat_medium" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="FR"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:fontFamily="@font/montserrat_medium" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="SA"
                    android:textColor="#888888"
                    android:textSize="11sp"
                    android:fontFamily="@font/montserrat_medium" />
            </LinearLayout>

            <!-- Calendar Days Grid -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvCalendarDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:clipToPadding="false"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="7"
                tools:itemCount="35"
                tools:listitem="@layout/item_calendar_day" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Selected Date Display at the Bottom -->
    <TextView
        android:id="@+id/tvSelectedDateDetails"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:layout_marginStart="24dp"
        android:text="Friday, 17 Jul, 2026"
        android:textColor="#333333"
        android:textSize="18sp"
        android:fontFamily="@font/montserrat_bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardCalendar" />

</androidx.constraintlayout.widget.ConstraintLayout>
